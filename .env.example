# ============================================
# 定然數位公關 週報系統 - 環境變數設定
# ============================================
# 複製此檔案為 .env，填入你的實際值
# 注意：.env 檔案不要上傳至 GitHub（已在 .gitignore 中排除）

# Google API 設定
# 前往 https://console.cloud.google.com 取得
REACT_APP_GOOGLE_API_KEY=你的_Google_API_Key
REACT_APP_GOOGLE_CLIENT_ID=你的_Google_Client_ID

# Google Sheets 試算表 ID
# 從試算表網址中取得：https://docs.google.com/spreadsheets/d/【這裡】/edit
REACT_APP_SPREADSHEET_ID=你的_試算表_ID

# Google Drive 根資料夾 ID
# 從資料夾網址中取得：https://drive.google.com/drive/folders/【這裡】
REACT_APP_DRIVE_FOLDER_ID=你的_Drive資料夾_ID

# Anthropic API Key
# 前往 https://console.anthropic.com 取得
REACT_APP_ANTHROPIC_API_KEY=你的_Anthropic_API_Key
